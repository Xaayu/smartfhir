# Backend
ADMIN_TOKEN=change-me-before-deploy
FRONTEND_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Optional persistent database
# DATABASE_URL=postgresql://user:password@host:5432/database
# SUPABASE_DB_URL=postgresql://user:password@host:5432/database
